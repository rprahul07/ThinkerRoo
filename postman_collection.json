{
	"info": {
		"_postman_id": "4ba98b0f-155e-4efb-86d1-4df2b1ff1d73",
		"name": "Internship API",
		"description": "CRUD routes for the users table via Supabase, plus JWT auth (register / login)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "userId",
			"value": "replace-with-a-real-uuid"
		},
		{
			"key": "token",
			"value": "",
			"description": "JWT access token – auto-set by the Login / Register test scripts"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"    console.log('token saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"user@example.com\",\n    \"password\": \"secret123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Create a new user account. Returns a JWT token on success (201). Token is auto-saved to {{token}}."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var json = pm.response.json();",
									"if (json.token) {",
									"    pm.collectionVariables.set('token', json.token);",
									"    console.log('token saved:', json.token.substring(0, 20) + '...');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"secret123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Login with email and password. Returns JWT (200). Token is auto-saved to {{token}} collection variable."
					},
					"response": []
				}
			]
		},
		{
			"name": "Upload",
			"item": [
				{
					"name": "Upload Photo",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "photo",
									"type": "file",
									"src": "",
									"description": "Image file to upload"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/upload",
							"host": ["{{baseUrl}}"],
							"path": ["upload"]
						},
						"description": "Upload a photo to S3. Requires JWT in Authorization header. Returns a pre-signed URL (valid 1 hour) and the S3 key on success (201)."
					},
					"response": []
				},
				{
					"name": "Delete Photo",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"key\": \"uploads/<your-user-id>/<filename>.jpg\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/upload",
							"host": ["{{baseUrl}}"],
							"path": ["upload"]
						},
						"description": "Delete a previously uploaded photo from S3. Requires JWT. The key must belong to the authenticated user (must start with uploads/<userId>/)."
					},
					"response": []
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profile/all",
							"host": ["{{baseUrl}}"],
							"path": ["profile", "all"]
						}
					},
					"response": []
				},
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\",\n    \"role\": \"Lead Engineer\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profile/all",
							"host": ["{{baseUrl}}"],
							"path": ["profile", "all"]
						}
					},
					"response": []
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profile", "{{userId}}"]
						}
					},
					"response": []
				},
				{
					"name": "Update User",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Smith\",\n    \"role\": \"Senior Engineer\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profile", "{{userId}}"]
						}
					},
					"response": []
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["profile", "{{userId}}"]
						}
					},
					"response": []
				}
			]
		}
	]
}
