{
	"info": {
		"_postman_id": "4ba98b0f-155e-4efb-86d1-4df2b1ff1d73",
		"name": "Internship API",
		"description": "CRUD routes for the users table via Supabase",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "userId",
			"value": "replace-with-a-real-uuid"
		}
	],
	"item": [
		{
			"name": "Get All Users",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/profile/all",
					"host": ["{{baseUrl}}"],
					"path": ["profile", "all"]
				}
			},
			"response": []
		},
		{
			"name": "Create User",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\",\n    \"role\": \"Lead Engineer\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/profile/all",
					"host": ["{{baseUrl}}"],
					"path": ["profile", "all"]
				}
			},
			"response": []
		},
		{
			"name": "Get User by ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/profile/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["profile", "{{userId}}"]
				}
			},
			"response": []
		},
		{
			"name": "Update User",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"Jane Smith\",\n    \"role\": \"Senior Engineer\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/profile/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["profile", "{{userId}}"]
				}
			},
			"response": []
		},
		{
			"name": "Delete User",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/profile/{{userId}}",
					"host": ["{{baseUrl}}"],
					"path": ["profile", "{{userId}}"]
				}
			},
			"response": []
		}
	]
