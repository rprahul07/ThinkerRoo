# Base URL of the backend profile API (must be prefixed with VITE_ to be
# exposed to the client by Vite). No trailing slash.
#
# Local development:
#   VITE_PUBLIC_API_BASE=http://localhost:3000/profile
#
# Netlify: set this in Site settings → Environment variables to your
# deployed backend URL, e.g. https://your-backend.onrender.com/profile

VITE_PUBLIC_API_BASE=http://localhost:3000/profile
